# ============================================================
# ACHADINHOS V3 — Configuração
# Copie pra .env e preencha
# ============================================================

# ── App ──────────────────────────────────────────────────
APP_NAME=Achadinhos
APP_ENV=development               # development | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# Porta do servidor (dentro do container é fixa em 8000)
HOST_PORT=8000

# URL pública do app (sem path final). Usada pelo auto-registro do agente
# pra entregar URLs absolutas (api_url, ws_url) e em emails futuros.
# Dev:  http://localhost:8000
# Prod: https://achadinhos.seudominio.com.br
PUBLIC_BASE_URL=http://localhost:8000

# ── Segredos (TROCAR EM PRODUÇÃO!) ───────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=troque-isso-em-producao-com-uma-string-aleatoria-longa
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Cifragem de credenciais de plataformas (ML/Shopee/Amazon).
# TROCAR A CHAVE INVALIDA TODAS AS SENHAS CIFRADAS — re-cadastrar.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
CREDENCIAIS_SECRET_KEY=troque-isso-em-producao-pelo-menos-32-chars-aleatorios

# ── Banco (Postgres) ─────────────────────────────────────
POSTGRES_USER=achadinhos
POSTGRES_PASSWORD=achadinhos_dev_pwd
POSTGRES_DB=achadinhos
POSTGRES_HOST=postgres            # nome do serviço no docker-compose
POSTGRES_PORT=5432

# ── Redis (filas + cache) ────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Admin inicial (criado via scripts/criar_admin.py) ────
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@local
ADMIN_ORG_NOME=Achadinhos

# ── Afiliados (defaults globais — podem ser sobrescritos por org) ──
ML_AFFILIATE_ID=
SHOPEE_AFFILIATE_ID=
AMAZON_AFFILIATE_TAG=
MAGALU_AFFILIATE_ID=
ALIEXPRESS_AFFILIATE_ID=

# ── Telegram (opcional, configurável por org via dashboard) ─────
# Cada org cadastra o próprio bot token via interface — esse aqui é só fallback
TELEGRAM_BOT_TOKEN_GLOBAL=

# ── Anthropic (frase de desejo do produto) ───────────────
ANTHROPIC_API_KEY=

# ── Limites globais (defaults) ────────────────────────────
MAX_AGENTES_POR_ORG=20
MAX_POSTAGENS_DIA_DEFAULT=500
